<!-- Order Details Section -->

<div class="order-details-container">

    <!-- Breadcrumb -->
    <div class="breadcrumb">
        <span><a href="/admin/orders">Orders</a></span>
        <span class="divider">/</span>
        <span class="active">
            <%= order.orderId %>
        </span>
    </div>

    <!-- Header -->
    <div class="order-header">
        <div>
            <h2>Order <%= order.orderId %>
            </h2>
            <p>Placed on <%= new Date(order.createdAt).toLocaleString("en-US", { month: "short" , day: "2-digit" ,
                    year: "numeric" , hour: "numeric" , minute: "2-digit" , hour12: true }).replace("AM", "a.m."
                    ).replace("PM", "p.m." ) %>
            </p>
        </div>

        <span class="order-badge status-<%= order.orderStatus %>">
            <%= order.orderStatus %>
        </span>
    </div>

    <!-- Layout -->
    <div class="order-layout">

        <!-- Left Section -->
        <div class="order-left">

            <!-- Order Items -->
            <div class="card">
                <h3>Order Items</h3>

                <table class="items-table">

                    <thead>
                        <tr>
                            <th>Product</th>
                            <th>Unit Price</th>
                            <th>GST rate</th>
                            <th>Total</th>
                            <th>Action</th>
                        </tr>
                    </thead>

                    <tbody id="orderItems">
                        <% order.products.forEach((product)=>{ %>
                            <tr>

                                <td>
                                    <div class="product-box">
                                        <img src="<%= product.image %>">
                                        <div>
                                            <div class="product-name">
                                                <%= product.name %>
                                            </div>
                                            <div class="product-size">Size: <%= product.size %> | Qty: <%=
                                                        product.quantity %>
                                            </div>
                                        </div>
                                    </div>
                                </td>

                                <td>₹<%= product.price %> × <%= product.quantity %>
                                </td>
                                <td>
                                    <%= product.gst_rate %>% (₹<%= product.unit_gst%> × <%= product.quantity %>)
                                </td>
                                <td>₹<%= (product.subtotal).toFixed(2) %>
                                </td>
                                <td><span class="order-badge">
                                        <%= product.status %>
                                    </span></td>
                            </tr>

                            <% }) %>

                    </tbody>

                </table>
            </div>

            <!-- Financials -->
            <div class="card">
                <h3>Order Financials</h3>

                <div class="finance-row">
                    <span>Subtotal</span>
                    <span id="subTotal">₹<%= (order.itemsPrice).toFixed(2) %></span>
                </div>

                <div class="finance-row">
                    <span>Shipping</span>
                    <span id="shipping">₹<%= (order.shippingCharge).toFixed(2) %></span>
                </div>

                <div class="finance-row">
                    <span>GST</span>
                    <span id="discount">₹<%= (order.totalGST).toFixed(2) %></span>
                </div>

                <hr>

                <div class="finance-row total">
                    <span>Grand Total</span>
                    <span id="grandTotal">₹<%= (order.totalPrice).toFixed(2) %></span>
                </div>
            </div>

            <% if(order.is_couponed){%>
                <div class="card">
                    <h3>Coupon Applied</h3>

                    <div class="finance-row">
                        <span>Coupon Code</span>
                        <span id="couponCode">
                            <%= order.coupon.code %>
                        </span>
                    </div>

                    <div class="finance-row">
                        <span>Coupon Discount Type</span>
                        <span id="">
                            <%= order.coupon.discountType %>
                        </span>
                    </div>
                    <% let disValue=`₹${order.coupon.discountValue}` ; if (order.coupon && order.coupon.discountType==="percentage" ) {
                        disValue=`${order.coupon.discountValue}%`; } %>

                        <div class="finance-row">
                            <span>Coupon Discount Value</span>
                            <span>
                                <%= disValue %>
                            </span>
                        </div>

                        <hr>

                        <div class="finance-row total">
                            <span>Discount Amount</span>
                            <span id="">₹<%= order.coupon.discountAmount %></span>
                        </div>
                </div>
                <%}%>

        </div>

        <!-- Right Section -->
        <div class="order-right">

            <!-- Manage -->
            <div class="card">
                <h3>Manage Order</h3>

                <label>Order Status</label>
                <select id="orderStatus">
                    <option value="Placed" <%=order.orderStatus==="Placed" ? "selected" :"" %> >Placed</option>
                    <option value="Confirmed" <%=order.orderStatus==="Confirmed" ? "selected" :"" %> >Confirmed</option>
                    <option value="Packed" <%=order.orderStatus==="Packed" ? "selected" :"" %> >Packed</option>
                    <option value="Shipped" <%=order.orderStatus==="Shipped" ? "selected" :"" %> >Shipped</option>
                    <option value="OutForDelivery" <%=order.orderStatus==="OutForDelivery" ? "selected" :"" %> >Out for
                        delivery</option>
                    <option value="Delivered" <%=order.orderStatus==="Delivered" ? "selected" :"" %> >Delivered</option>
                    <option value="Cancelled" <%=order.orderStatus==="Cancelled" ? "selected" :"" %> >Cancelled</option>
                    <option value="Returned" <%=order.orderStatus==="Returned" ? "selected" :"" %> >Returned</option>
                </select>

                <label>Payment Status</label>
                <select id="paymentStatus">
                    <option <%=order.paymentStatus==="Pending" ? "selected" :"" %> >Pending</option>
                    <option <%=order.paymentStatus==="Paid" ? "selected" :"" %> >Paid</option>
                    <option <%=order.paymentStatus==="Failed" ? "selected" :"" %> >Failed</option>
                </select>

                <button class="btn-primary" data-order-id="<%= order._id %>" id="updateStatus">Update Status</button>
            </div>

            <!-- Customer -->
            <div class="card">
                <h3>Customer</h3>

                <p class="customer-name">
                    <%=order.user_id.full_name%>
                </p>
                <p>
                    <%=order.user_id.email%>
                </p>
            </div>

            <!-- Payment -->
            <div class="card">
                <h3>Payment Method</h3>

                <h5>
                    <%= order.paymentMethod==="COD" ?"Cash On Delivery": order.paymentMethod %>
                </h5>
            </div>

            <!-- Address -->
            <div class="card">
                <h3>Shipping Address</h3>

                <p>
                    <%= order.shippingAddress.full_name %>
                </p>
                <p>
                    <%= order.shippingAddress.address_line %>
                </p>
                <p>
                    <%= order.shippingAddress.city %> - <%= order.shippingAddress.zip_code %>
                </p>
                <p>
                    <%= order.shippingAddress.country %>, <%= order.shippingAddress.state %>
                </p>
                <p>Phone: <%= order.shippingAddress.phone_no %>
                </p>
            </div>

        </div>

    </div>

</div>