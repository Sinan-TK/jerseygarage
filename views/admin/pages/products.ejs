<div class="product-page">

    <div class="page-header">
        <h2>Products</h2>
        <p class="page-subtext">View product inventory and prices.</p>

        <button class="add-btn"><span>+</span>Add Product</button>
    </div>

    <div class="product-container">

        <!-- FILTER BAR -->
        <div class="product-filter-bar">

            <input type="text" id="searchInput" class="product-search" placeholder="Search products...">

            <div class="filter-dropdown" id="statusDropdown">
                <div class="dropdown-selected">All Products</div>
                <ul class="dropdown-options">
                    <li data-value="all">All Products</li>
                    <li data-value="active">Active</li>
                    <li data-value="inactive">Inactive</li>
                </ul>
            </div>

            <button id="applyFilter" class="btn-apply">Apply</button>
            <button id="clearFilter" class="btn-clear">Clear</button>
        </div>

        <!-- PRODUCT TABLE -->
        <table class="product-table">
            <thead>
                <tr>
                    <th></th>
                    <th>Image</th>
                    <th>Product</th>
                    <th>Category</th>
                    <th>Status</th>
                    <th>Edit</th>
                    <th>Action</th>
                </tr>
            </thead>

            <tbody id="productTableBody">

                <% products.forEach(product=> { %>

                    <!-- MAIN PRODUCT ROW -->
                    <tr class="product-row" data-id="<%= product._id %>" data-name="<%= product.name.toLowerCase() %>"
                        data-status="<%= product.is_active ? 'active' : 'inactive' %>">

                        <!-- DROPDOWN ARROW -->
                        <td class="arrow-cell">
                            <i class="fa-solid fa-chevron-down row-arrow" data-id="<%= product._id %>"></i>
                        </td>

                        <!-- IMAGE -->
                        <td class="image-cell">
                            <img src="<%= product.images[0] %>" class="product-thumb">
                        </td>

                        <!-- PRODUCT NAME -->
                        <td>
                            <%= product.name %>
                        </td>

                        <!-- CATEGORY -->
                        <td>
                            <%categoriesName.forEach(category=>{if(category._id.toString() == product.category.toString()){%>
                                <%=category.name%>
                                    <%}})%>

                        </td>

                        <!-- STATUS -->
                        <td>
                            <span class="status-badge <%= product.is_active ? 'active' : 'inactive' %>">
                                <%= product.is_active ? 'List' : 'Unlist' %>
                            </span>
                        </td>

                        <!-- EDIT -->
                        <td>
                            <a href="/admin/products/edit/<%= product._id %>" class="edit-btn">
                                <i class="fa-solid fa-pen-to-square"></i> Edit
                            </a>
                        </td>

                        <!-- ACTION -->
                        <td>
                            <% if (product.is_active) { %>
                                <span class="action-btn block"><i class="fa-solid fa-ban block-icon"></i> Block</span>
                                <% } else { %>
                                    <span class="action-btn list"><i class="fa-solid fa-unlock unblock-icon"></i>
                                        List</span>
                                    <% } %>
                        </td>
                    </tr>

                    <!-- DROPDOWN ROW -->
                    <tr class="dropdown-row" id="drop-<%= product._id %>">
                        <td colspan="7">
                            <div class="dropdown-box">
                                <table class="size-preview-table">
                                    <thead>
                                        <tr>
                                            
                                            <th></th>
                                            <th>S</th>
                                            <th>M</th>
                                            <th>L</th>
                                            <th>XL</th>
                                            <th>XXL</th>
                                        </tr>
                                    </thead>

                                    <tbody>
                                        <tr>
                                            <td>Stock</td>
                                            <td><%= product.sizes[0].stock%></td>
                                            <td><%= product.sizes[1].stock%></td>
                                            <td><%= product.sizes[2].stock%></td>
                                            <td><%= product.sizes[3].stock%></td>
                                            <td><%= product.sizes[4].stock%></td>
                                        </tr>

                                        <tr>
                                            <td>Normal Price</td>
                                            <td><%= product.sizes[0].normalPrice%></td>
                                            <td><%= product.sizes[1].normalPrice%></td>
                                            <td><%= product.sizes[2].normalPrice%></td>
                                            <td><%= product.sizes[3].normalPrice%></td>
                                            <td><%= product.sizes[4].normalPrice%></td>
                                        </tr>

                                        <tr>
                                            <td>Base Price</td>
                                            <td><%= product.sizes[0].basePrice%></td>
                                            <td><%= product.sizes[1].basePrice%></td>
                                            <td><%= product.sizes[2].basePrice%></td>
                                            <td><%= product.sizes[3].basePrice%></td>
                                            <td><%= product.sizes[4].basePrice%></td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </td>
                    </tr>

                    <% }) %>

            </tbody>
        </table>
        <!-- PAGINATION -->
        <div class="pagination">

            <!-- LEFT ARROW: show ONLY if NOT first page -->
            <% if (currentPage> 1) { %>
                <a href="/admin/users?page=<%= currentPage - 1 %>" class="arrow-btn">
                    <i class="fa-solid fa-chevron-left"></i>
                </a>
                <% } %>

                    <!-- CURRENT PAGE NUMBER -->
                    <span class="current-page-display">
                        <%= currentPage %>
                    </span>

                    <!-- RIGHT ARROW: show ONLY if NOT last page -->
                    <% if (currentPage < totalPages) { %>
                        <a href="/admin/users?page=<%= currentPage + 1 %>" class="arrow-btn">
                            <i class="fa-solid fa-chevron-right"></i>
                        </a>
                        <% } %>

        </div>

    </div>
</div>






<!-- ADD PRODUCT MODAL -->
<div id="addProductModal" class="modal-overlay">
    <div class="modal">

        <!-- HEADER -->
        <div class="modal-header">
            <h2>Add New Product</h2>
            <span class="close-btn">✕</span>
        </div>

        <!-- PRODUCT NAME + CATEGORY -->
        <div class="form-row">
            <div class="input-group">
                <label>Product Name <span class="star-icon">*</span></label>
                <input id="productName" type="text" name="productName" placeholder="Product Name">
            </div>

            <div class="input-group">
                <label>Category <span class="star-icon">*</span></label>

                <div class="categoryDrop">
                    <div class="dropdown-cat-selected" value="">Select Category</div>
                    <ul class="dropdown-cat-options">
                        <% categoriesName.forEach(cat=>{ %>
                            <li data-value="<%= cat.name %>">
                                <%= cat.name %>
                            </li>
                            <% }) %>
                    </ul>
                </div>

                <input id="seleted-category" type="hidden" name="category" value="null">
            </div>
        </div>

        <!-- TEAM NAME -->
        <div class="form-row">
            <div class="input-group">
                <label>Team/Club Name <span class="star-icon">*</span></label>
                <input type="text" id="teamName" name="teamName" placeholder="Team/Club Name">
            </div>
        </div>

        <!-- PRODUCT IMAGES -->
        <!-- Image Upload -->
        <label>Product Images <span class="star-icon">*</span></label>
        <div class="images-container">
            <div class="img-box">
                <label for="fileInput" class="custom-file-upload">Upload Images</label>
                <input id="fileInput" type="file" accept="image/*" multiple>

                <!-- PREVIEW (populated by JS) -->
                <div id="previewContainer" style="display:flex; gap:12px; flex-wrap:wrap; margin-top:12px;"></div>
            </div>
        </div>

        <!-- STOCK TABLE -->
        <label>Stock and Pricing by Size <span class="star-icon">*</span></label>
        <table class="stockTable">
            <tr>
                <th></th>
                <th>S</th>
                <th>M</th>
                <th>L</th>
                <th>XL</th>
                <th>XXL</th>
            </tr>

            <tr>
                <td>Stock</td>
                <% ['S','M','L','XL','XXL'].forEach(size=> { %>
                    <td><input class="stockInput" type="number" name="stock_<%= size %>"></td>
                    <% }) %>
            </tr>

            <tr>
                <td>Normal Price</td>
                <% ['S','M','L','XL','XXL'].forEach(size=> { %>
                    <td><input class="stockInput" type="number" name="normalPrice_<%= size %>"></td>
                    <% }) %>
            </tr>

            <tr>
                <td>Base Price</td>
                <% ['S','M','L','XL','XXL'].forEach(size=> { %>
                    <td><input class="stockInput" type="number" name="basePrice_<%= size %>"></td>
                    <% }) %>
            </tr>
        </table>

        <!-- DESCRIPTION -->
        <div class="input-group">
            <label>Description <span class="star-icon">*</span></label>
            <textarea id="description" name="description" placeholder="Enter product description..."></textarea>
        </div>

        <!-- FOOTER -->
        <div class="modal-footer">
            <button class="btn cancel-btn">Cancel</button>
            <button class="btn add-btn-confirm" onclick="submitProduct()">Add Product</button>
        </div>

    </div>
</div>


<!-- GLOBAL CROP MODAL (outside modal or at bottom of page) -->
<div id="cropModal"
    style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.7); z-index:999999; justify-content:center; align-items:center;">
    <div id="cropBox"
        style="background:white; padding:20px; border-radius:10px; max-width:95vw; max-height:95vh; overflow:auto; display:flex; flex-direction:column; align-items:center;">
        <img id="cropImage" style="max-width:100%; max-height:80vh; object-fit:contain; display:block; margin:auto;" />
        <div style="display:flex; gap:8px; justify-content:flex-end; width:100%; margin-top:12px;">
            <button id="cancelCropBtn" class="btn cancel-btn" type="button">Cancel</button>
            <button id="cropNextBtn" class="btn add-btn-confirm" type="button">Crop</button>
        </div>
    </div>
</div>