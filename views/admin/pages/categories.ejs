<div class="categories-page">

    <div class="top-header">
        <div>
            <h2>Categories</h2>
            <p>Organize your product categories</p>

            <!-- <form action="/categories/add" method="POST"> -->
            <button type="button" class="add-btn" onclick="openCategoryModal()">
                <span>+</span> Add Category
            </button>
            <!-- </form> -->
        </div>
        <div class="category-card">

            <form action="/admin/categories/search" method="GET">

                <!-- FILTER BAR -->
                <div class="filter-bar">

                    <input id="filterInput" class="search-category" name="searchContent"
                        value="<%= typeof searchContent !== 'undefined' ? searchContent : '' %>" placeholder="Search categories...">

                    <div class="custom-dropdown">
                        <div class="dropdown-selected">All Categories</div>
                        <ul class="dropdown-options">
                            <li data-value="all">All Categories</li>
                            <li data-value="active">Active Categories</li>
                            <li data-value="blocked">Blocked Categories</li>
                        </ul>

                    </div>
                    <input type="hidden" id="statusFilter" name="categoryStatus" value="all">

                    <button class="apply-btn">Apply</button>

                    <button id="clearFilter" type="submit" class="clear-btn">Clear</button>

            </form>

        </div>
    </div>
</div>

<div class="categories-grid">

    <!-- Category Card -->

    <% if(categories.length===0){ %>
        <div class="cat-card" style="--bg:#f7f7f7;">
            <div class="icon-box"><i class="fa-solid fa-exclamation"></i></div>
            <h3>No category found</h3>
            <p class="desc"></p>
            <p class="coun"><strong></strong> </p>
            <div class="actions">
            </div>
        </div>
        <% } %>

            <% categories.forEach(category=> { %>
                <div class="cat-card" data-id="<%= category._id %>" data-name="<%= category.name %>"
                    style="--bg:<%= category.color %>;">
                    <div class="icon-box"><i class="fa-regular fa-folder"></i></div>
                    <h3>
                        <%= category.name %>
                    </h3>
                    <p class="desc">
                        <%= category.description %>
                    </p>

                    <p class="status <%= category.is_active ? 'active' : 'inactive' %>" data-id="<%= category._id %>">
                        <%= category.is_active ? 'Active' : 'Blocked' %>
                    </p>


                    <div class="actions">
                        <button class="edit" data-id="<%= category._id %>" data-name="<%= category.name %>"
                            data-description="<%= category.description %>" data-color="<%= category.color %>"
                            onclick="openEditModal()">Edit</button>
                        <button class="view" onclick="openModalProductList()">View Products</button>
                        <button
                            class="cat-action <%= category.is_active ? 'block block-category' : 'unblock unblock-category' %>"
                            data-name="<%= category.name %>" data-id="<%= category._id %>">
                            <%= category.is_active ? 'Block' : 'Unblock' %>
                        </button>
                    </div>
                </div>

                <% }); %>

</div>
</div>

<div class="pagination">

    <!-- LEFT ARROW: show ONLY if NOT first page -->
    <% if (currentPage> 1) { %>
        <a href="/admin/categories?page=<%= currentPage - 1 %>" class="arrow-btn">
            <i class="fa-solid fa-chevron-left"></i>
        </a>
        <% } %>

            <!-- CURRENT PAGE NUMBER -->
            <span class="current-page-display">
                <%= currentPage %>
            </span>

            <!-- RIGHT ARROW: show ONLY if NOT last page -->
            <% if (currentPage < totalPages) { %>
                <a href="/admin/categories?page=<%= currentPage + 1 %>" class="arrow-btn">
                    <i class="fa-solid fa-chevron-right"></i>
                </a>
                <% } %>

</div>

