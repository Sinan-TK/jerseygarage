<div class="categories-page">

    <div class="top-header">
        <div>
            <div>
                <div>
                    <h2>Categories</h2>
                    <p>Organize your product categories</p>
                </div>

                <div>
                    <button type="button" class="add-btn" onclick="openCategoryModal()">
                        <span>+</span> Add Category
                    </button>
                </div>
            </div>
        </div>
        <div class="category-card">

            <!-- <form action="/admin/categories/search" method="GET"> -->

                <!-- FILTER BAR -->
                <div class="filter-bar">

                    <input id="filterInput" class="search-category" name="searchContent"
                        placeholder="Search categories...">

                    <div class="custom-dropdown">
                        <div class="dropdown-selected">All Categories</div>
                        <ul class="dropdown-options">
                            <li data-value="all">All Categories</li>
                            <li data-value="active">Active Categories</li>
                            <li data-value="blocked">Blocked Categories</li>
                        </ul>

                    </div>
                    <input type="hidden" id="statusFilter" name="categoryStatus" value="all">

                    <button class="apply-btn">Apply</button>

                    <button id="clearFilter" type="submit" class="clear-btn">Clear</button>

            <!-- </form> -->

        </div>
    </div>
</div>

<div class="category-table-wrapper">

    <table class="category-table">
        <thead>
            <tr>
                <th>Category</th>
                <th>Description</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>

        <tbody id="categoryTableBody">


        </tbody>
    </table>
</div>

</div>

<div class="pagination">


</div>

<!-- view products modal -->

<!-- Overlay -->
<div id="viewProductsModal" class="modal-overlay">

    <!-- Modal Box -->
    <div class="modal-box">

        <!-- Header -->
        <div class="modal-header">
            <div>
                <h2 id="category-heading">name</h2>
                <p id="category-description">description</p>
            </div>
            <button class="close-modal">&times;</button>
        </div>

        <!-- Product List -->
        <div class="modal-products"></div>

        <!-- Footer -->
        <div class="modal-footer">
            <button class="close-footer">Close</button>
        </div>

    </div>
</div>

<!-- Overlay modal add category -->
<div id="categoryModal" class="modal-overlay">
    <div class="modal">

        <!-- Header -->
        <div class="modal-header">
            <h2>Add Category</h2>
            <span class="close-btn close-category-modal" id="closeModal">&times;</span>
        </div>

        <!-- ERROR MESSAGE -->
        <div id="addError" class="error-box" style="display:none;">
            <i class="fa-solid fa-circle-exclamation"></i>
            <span id="addErrorText"></span>
        </div>

        <!-- Form -->
        <div id="categoryForm" action="/admin/categories/add" method="POST">

            <label>Category Name</label>
            <input type="text" name="name" id="addCategoryName" class="input-field" placeholder="Category Name">

            <label>Description</label>
            <textarea name="description" id="addCategoryDescription" class="input-field" rows="3"
                placeholder="Write description..."></textarea>

            <!-- Buttons -->
            <div class="modal-actions">
                <button type="button" class="cancel-btn close-category-modal">Cancel</button>
                <button type="submit" class="save-btn" onclick="addCategory()">Save</button>
            </div>
        </div>

    </div>
</div>


<!-- Overlay modal edit category -->
<div id="editCategoryModal" class="modal-overlay">
    <div class="modal">

        <!-- Header -->
        <div class="modal-header">
            <h2>Edit Category</h2>
            <span class="close-btn close-category-modal close-edit-modal" id="closeModal">&times;</span>
        </div>

        <!-- ERROR MESSAGE -->
        <div id="editError" class="error-box" style="display:none;">
            <i class="fa-solid fa-circle-exclamation"></i>
            <span id="editErrorText"></span>
        </div>

        <!-- Form -->
        <div id="editCategoryForm">

            <!-- <input type="text" type="hidden" id="categoryId" value="" > -->

            <label>Category Name</label>
            <input type="text" name="name" class="input-field" id="editCategoryName" placeholder="Category Name">

            <label>Description</label>
            <textarea name="description" id="editCategoryDescription" class="input-field" rows="3"
                placeholder="Write description..."></textarea>

            <!-- Buttons -->
            <div class="modal-actions">
                <button type="button" class="cancel-btn close-category-modal close-edit-modal">Cancel</button>
                <button type="submit" class="save-btn" onclick="editConfirm()">Save Changes</button>
            </div>
        </div>

    </div>
</div>


<!-- CONFIRM MODAL -->
<div id="confirmModal" class="confirm-modal">
    <div class="modal-content">
        <h3 id="modalTitle">Confirm Action</h3>
        <p id="modalMessage">Are you sure?</p>

        <div class="modal-buttons">
            <button id="cancelBtn" class="cancel-btn">Cancel</button>
            <a id="confirmBtn" class="confirm-btn" onclick="blockConfirm()">Yes, Continue</a>
        </div>
    </div>
</div>