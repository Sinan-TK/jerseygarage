<!-- Overlay modal add category -->
<div id="categoryModal" class="modal-overlay">
    <div class="modal">

        <!-- Header -->
        <div class="modal-header">
            <h2>Add Category</h2>
            <span class="close-btn close-category-modal" id="closeModal">&times;</span>
        </div>

        <!-- ERROR MESSAGE -->
        <div id="addError" class="error-box" style="display:none;">
            <i class="fa-solid fa-circle-exclamation"></i>
            <span id="addErrorText"></span>
        </div>

        <!-- Form -->
        <div id="categoryForm" action="/admin/categories/add" method="POST">

            <label>Category Name</label>
            <input type="text" name="name" id="addCategoryName" class="input-field" placeholder="Category Name">

            <label>Description</label>
            <textarea name="description" id="addCategoryDescription" class="input-field" rows="3" placeholder="Write description..."></textarea>

            <label>Color Theme</label>

            <div class="color-grid">
                <div class="color-box" data-color="#dfeafe" style="background:#dfeafe"></div>
                <div class="color-box" data-color="#f4e9ff" style="background:#f4e9ff"></div>
                <div class="color-box" data-color="#e2ffe9" style="background:#e2ffe9"></div>
                <div class="color-box" data-color="#fff5c6" style="background:#fff5c6"></div>
                <div class="color-box" data-color="#ffe1e1" style="background:#ffe1e1"></div>
                <div class="color-box" data-color="#f7f7f7" style="background:#f7f7f7"></div>
            </div>

            <input type="hidden"  name="color" id="selectedColor">

            <!-- Buttons -->
            <div class="modal-actions">
                <button type="button" class="cancel-btn close-category-modal">Cancel</button>
                <button type="submit" class="save-btn" onclick="addCategory()">Save</button>
            </div>
        </div>

    </div>
</div>


<!-- Overlay modal edit category -->
<div id="editCategoryModal" class="modal-overlay">
    <div class="modal">

        <!-- Header -->
        <div class="modal-header">
            <h2>Edit Category</h2>
            <span class="close-btn close-category-modal close-edit-modal" id="closeModal">&times;</span>
        </div>

        <!-- ERROR MESSAGE -->
        <div id="editError" class="error-box" style="display:none;">
            <i class="fa-solid fa-circle-exclamation"></i>
            <span id="editErrorText"></span>
        </div>

        <!-- Form -->
        <div id="editCategoryForm">

            <!-- <input type="text" type="hidden" id="categoryId" value="" > -->

            <label>Category Name</label>
            <input type="text" name="name" class="input-field" id="editCategoryName" placeholder="Category Name">

            <label>Description</label>
            <textarea name="description" id="editCategoryDescription" class="input-field" rows="3"
                placeholder="Write description..."></textarea>

            <label>Color Theme</label>

            <div class="color-grid">
                <div class="color-box color-box-edit" data-color="#dfeafe" style="background:#dfeafe"></div>
                <div class="color-box color-box-edit" data-color="#f4e9ff" style="background:#f4e9ff"></div>
                <div class="color-box color-box-edit" data-color="#e2ffe9" style="background:#e2ffe9"></div>
                <div class="color-box color-box-edit" data-color="#fff5c6" style="background:#fff5c6"></div>
                <div class="color-box color-box-edit" data-color="#ffe1e1" style="background:#ffe1e1"></div>
                <div class="color-box color-box-edit" data-color="#f7f7f7" style="background:#f7f7f7"></div>
            </div>

            <input type="hidden" id="editCategoryColor" name="color">

            <!-- Buttons -->
            <div class="modal-actions">
                <button type="button" class="cancel-btn close-category-modal close-edit-modal">Cancel</button>
                <button type="submit" class="save-btn" onclick="editConfirm()">Save Changes</button>
            </div>
        </div>

    </div>
</div>


<!-- CONFIRM MODAL -->
<div id="confirmModal" class="confirm-modal">
    <div class="modal-content">
        <h3 id="modalTitle">Confirm Action</h3>
        <p id="modalMessage">Are you sure?</p>

        <div class="modal-buttons">
            <button id="cancelBtn" class="cancel-btn">Cancel</button>
            <a id="confirmBtn" class="confirm-btn" onclick="blockConfirm()">Yes, Continue</a>
        </div>
    </div>
</div>

<script>window.userStatusFromServer = "<%= typeof categoryStatus !== 'undefined' ? categoryStatus : 'all' %>";</script>
