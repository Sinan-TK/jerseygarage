<div class="fp-wrap">

    <div class="fp-card">
        <h1 class="fp-title">Forgot Password</h1>
        <p class="fp-sub">Enter your email address to receive a OTP.</p>

        <div class="form-group">
            <label for="fp-email">Email Address</label>
            <input type="email" id="fp-email" placeholder="Enter your email" autocomplete="email">
            <span class="error-msg" id="fp-err"></span>
        </div>

        <button class="fp-btn" id="fp-send-btn">Send OTP</button>

        <a class="fp-back" href="/admin/login">
            <i class="fa-solid fa-arrow-left"></i>
            Return to Sign In
        </a>
    </div>

</div>