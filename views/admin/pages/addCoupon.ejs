<div class="page-content">

    <div class="breadcrumb">
        <span><a href="/admin/coupons">Coupons</a></span>
        <span class="separator">/</span>
        <span class="current">
            <%= title==="Add Coupon" ?"Add Coupon":"Edit Coupon"%>
        </span>
    </div>

    <div class="page-header">
        <div>
            <h2>
                <%= title==="Add Coupon" ? "Add" :"Edit"%> Coupon
            </h2>
            <p>Create a new product or category coupon</p>
        </div>
    </div>

    <div class="card">

        <form id="addCouponForm" class="coupon-form">

            <!-- Row 1 -->
            <div class="form-grid">
                <div class="form-group">
                    <label>Coupon Code <span>*</span></label>
                    <input type="text" name="code" placeholder="SAVE10">
                </div>

                <div class="form-group">
                    <label>Discount Type <span>*</span></label>
                    <select name="discountType">
                        <option value="percentage">Percentage</option>
                        <option value="flat">Flat</option>
                    </select>
                </div>

            </div>

            <!-- Row 2 -->
            <div class="form-grid">
                <div class="form-group">
                    <label>Discount Value <span>*</span></label>
                    <input type="number" name="discountValue">
                </div>

                <div class="form-group">
                    <label>Minimum Purchase Amount <span>*</span></label>
                    <input type="number" name="minPurchaseAmount" value="0">
                </div>

            </div>

            <!-- Row 3 -->
            <div class="form-grid">

                <div class="form-group">
                    <label>Maximum Discount Amount <span>*</span></label>
                    <input type="number" name="maxDiscountAmount">
                </div>

                <div class="form-group">
                    <label>Total Usage Limit <span>*</span></label>
                    <input type="number" name="usageLimit" value="1">
                </div>

            </div>

            <!-- Row 4 -->
            <div class="form-grid">

                <div class="form-group">
                    <label>Per User Limit <span>*</span></label>
                    <input type="number" name="perUserLimit" value="1">
                </div>

                <div class="form-group">
                    <label>Expiry Date <span>*</span></label>
                    <input type="date" name="expiryDate">
                </div>

            </div>


            <!-- Description (Full Width) -->
            <div class="form-group full-width">
                <label>Description</label>
                <textarea name="description" rows="3" placeholder="10% off on orders above ₹999"></textarea>
            </div>

            <!-- Status -->
            <div class="form-group status-bar">
                <label>Status</label>
                <label class="switch">
                    <input type="checkbox" name="isActive" checked>
                    <span class="slider"></span>
                </label>
                <span>Active</span>
            </div>

            <!-- Actions -->
            <div class="form-actions">
                <a href="/admin/coupons" class="btn-secondary">Cancel</a>
                <button type="submit" class="btn-primary"><%= title==="Add Coupon" ? "Create Coupon" :"Submit"%></button>
            </div>

        </form>

    </div>
</div>