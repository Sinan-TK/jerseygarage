<section class="product-offer-section">

    <!-- Header -->
    <div class="offer-header">
        <div>
            <h2>Offers</h2>
            <p>Manage product and category discount offers</p>
        </div>

        <button class="create-offer-btn">
            <i class="bi bi-plus"></i> Create Offer
        </button>
    </div>


    <!-- Filters Row -->
    <div class="offer-filters">

        <!-- Search -->
        <div class="filter-group search-group">
            <input type="text" id="searchInput" placeholder="Search offer name or product...">
            <i class="fa-solid fa-magnifying-glass search-icon"></i>
        </div>

        <!-- Offer Type Filter -->
        <div class="filter-group">
            <select id="typeFilter">
                <option value="">All Types</option>
                <option value="product">Product Offer</option>
                <option value="category">Category Offer</option>
            </select>
        </div>

        <!-- Status Filter -->
        <div class="filter-group">
            <select id="statusFilter">
                <option value="">All Status</option>
                <option value="active">Active</option>
                <option value="inactive">Inactive</option>
            </select>
        </div>

        <button class="submit-btn" id="filter-apply" type="button">Apply</button>
        <button class="clear-btn" id="filter-reset" type="button">Clear</button>

    </div>


    <!-- Table Card -->
    <div class="offer-table-card">
        <table class="offer-table">
            <thead>
                <tr>
                    <th>Offer Name</th>
                    <th>Applied To</th>
                    <th>Offer Type</th>
                    <th>Discount</th>
                    <th>Valid Period</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>

            <tbody id="offerTableBody">


            </tbody>
        </table>
        <div class="pagination">

        </div>
    </div>

</section>

<!-- Create Offer Modal -->
<div class="modal-overlay" id="createOfferModal">

    <div class="modal-container">

        <div class="modal-header">
            <h3>Create New Offer</h3>
            <button class="close-modal" id="closeModalBtn">&times;</button>
        </div>

        <form id="createOfferForm">

            <!-- Offer Name -->
            <div class="form-group">
                <label>Offer Name</label>
                <input type="text" id="offerName" placeholder="Enter offer name">
            </div>

            <!-- Apply Type -->
            <div class="form-group">
                <label>Offer Apply Type</label>
                <select id="applyType">
                    <option value="">Select Type</option>
                    <option value="product">Product Offer</option>
                    <option value="category">Category Offer</option>
                </select>
            </div>

            <!-- Product Search -->
            <div class="form-group hidden" id="productSearchGroup">
                <label>Select Product</label>
                <div class="searchable-dropdown">
                    <input type="text" id="productSearchInput" placeholder="Search product...">
                    <div class="dropdown-list" id="productDropdown"></div>
                </div>

                <!-- Multiple Preview -->
                <div class="selected-preview" id="selectedProductPreview"></div>
            </div>


            <!-- Category Search -->
            <div class="form-group hidden" id="categorySearchGroup">
                <label>Select Category</label>
                <div class="searchable-dropdown">
                    <input type="text" id="categorySearchInput" placeholder="Search category...">
                    <div class="dropdown-list" id="categoryDropdown"></div>
                </div>

                <!-- Multiple Preview -->
                <div class="selected-preview" id="selectedCategoryPreview"></div>
            </div>



            <!-- Discount Type -->
            <div class="form-group">
                <label>Discount Type</label>
                <select id="discountType">
                    <option value="">Select Discount Type</option>
                    <option value="percentage">Percentage</option>
                    <option value="flat">Flat</option>
                </select>
            </div>

            <!-- Discount Value -->
            <div class="form-group">
                <label>Discount Value</label>
                <input type="number" id="discountValue" placeholder="Enter discount value">
            </div>

            <!-- Dates -->
            <div class="form-row">
                <div class="form-group">
                    <label>Start Date</label>
                    <input type="date" id="startDate">
                </div>

                <div class="form-group">
                    <label>End Date</label>
                    <input type="date" id="endDate">
                </div>
            </div>

            <!-- Status -->
            <div class="form-group status-toggle">
                <label>Status</label>
                <label class="switch">
                    <input type="checkbox" id="offerStatus" checked>
                    <span class="slider"></span>
                </label>
                <span class="status-label">Active</span>
            </div>

            <!-- Buttons -->
            <div class="modal-actions">
                <button type="button" class="cancel-btn" id="cancelBtn">Cancel</button>
                <button type="submit" class="submit-btn">Create Offer</button>
            </div>

        </form>

    </div>
    <!-- Pagination -->
    <div class="pagination">

    </div>
</div>

<!-- Edit Offer Modal -->
<div class="modal-overlay" id="editOfferModal">

    <div class="modal-container">

        <div class="modal-header">
            <h3>Edit Offer</h3>
            <button class="close-modal" id="closeEditModalBtn">&times;</button>
        </div>

        <form id="editOfferForm">

            <input type="hidden" id="editOfferId">

            <!-- Offer Name -->
            <div class="form-group">
                <label>Offer Name</label>
                <input type="text" id="editOfferName">
            </div>

            <!-- Apply Type -->
            <div class="form-group">
                <label>Offer Apply Type</label>
                <select id="editApplyType">
                    <option value="product">Product Offer</option>
                    <option value="category">Category Offer</option>
                </select>
            </div>

            <!-- Product Search -->
            <div class="form-group hidden" id="editProductSearchGroup">
                <label>Select Product</label>
                <div class="searchable-dropdown">
                    <input type="text" id="editProductSearchInput" placeholder="Search product...">
                    <div class="dropdown-list" id="editProductDropdown"></div>
                </div>

                <div class="selected-preview" id="editSelectedProductPreview"></div>
            </div>


            <!-- Category Search -->
            <div class="form-group hidden" id="editCategorySearchGroup">
                <label>Select Category</label>
                <div class="searchable-dropdown">
                    <input type="text" id="editCategorySearchInput" placeholder="Search category...">
                    <div class="dropdown-list" id="editCategoryDropdown"></div>
                </div>

                <div class="selected-preview" id="editSelectedCategoryPreview"></div>
            </div>


            <!-- Discount Type -->
            <div class="form-group">
                <label>Discount Type</label>
                <select id="editDiscountType">
                    <option value="percentage">Percentage</option>
                    <option value="flat">Flat</option>
                </select>
            </div>

            <!-- Discount Value -->
            <div class="form-group">
                <label>Discount Value</label>
                <input type="number" id="editDiscountValue">
            </div>

            <!-- Dates -->
            <div class="form-row">
                <div class="form-group">
                    <label>Start Date</label>
                    <input type="date" id="editStartDate">
                </div>
                <div class="form-group">
                    <label>End Date</label>
                    <input type="date" id="editEndDate">
                </div>
            </div>

            <!-- Status -->
            <div class="form-group status-toggle">
                <label>Status</label>
                <label class="switch">
                    <input type="checkbox" id="editOfferStatus">
                    <span class="slider"></span>
                </label>
                <span class="status-label" id="editStatusLabel">Active</span>
            </div>

            <!-- Buttons -->
            <div class="modal-actions">
                <button type="button" class="cancel-btn" id="cancelEditBtn">Cancel</button>
                <button type="submit" class="submit-btn">Update Offer</button>
            </div>

        </form>

    </div>
</div>

<!-- Delete Confirmation Modal -->
<div class="modal-overlay" id="deleteOfferModal">

    <div class="modal-container delete-modal">

        <div class="modal-header">
            <h3>Delete Offer</h3>
            <button class="close-modal" id="closeDeleteModalBtn">&times;</button>
        </div>

        <div class="delete-content">
            <i class="fa-solid fa-triangle-exclamation warning-icon"></i>
            <p>Are you sure you want to delete this offer?</p>
            <span>This action cannot be undone.</span>
        </div>

        <div class="modal-actions">
            <button type="button" class="cancel-btn" id="cancelDeleteBtn">
                Cancel
            </button>
            <button type="button" class="delete-confirm-btn" id="confirmDeleteBtn">
                <i class="fa-solid fa-trash"></i> Delete
            </button>
        </div>

    </div>
</div>

<!-- Offer Details Modal -->
<div class="modal-overlay" id="offerDetailsModal">

    <div class="modal-container details-modal">

        <div class="modal-header">
            <h3>Offer Details</h3>
            <button class="close-modal" id="closeDetailsModalBtn">&times;</button>
        </div>

        <div class="details-body">

            <div class="details-row">
                <label>Offer Name:</label>
                <span id="detailOfferName"></span>
            </div>

            <div class="details-row">
                <label>Offer Type:</label>
                <span id="detailOfferType" class="offer-type"></span>
            </div>

            <div class="details-row">
                <label>Applied To:</label>
                <div id="detailAppliedTo" class="details-preview"></div>
            </div>

            <div class="details-row">
                <label>Discount:</label>
                <span id="detailDiscount"></span>
            </div>

            <div class="details-row">
                <label>Valid Period:</label>
                <span id="detailDateRange"></span>
            </div>

            <div class="details-row">
                <label>Status:</label>
                <span id="detailStatus" class="active"></span>
            </div>

        </div>

        <div class="modal-actions">
            <button class="details-cancel-btn" id="closeDetailsBtn">Close</button>
        </div>

    </div>

</div>