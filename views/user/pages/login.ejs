<main class="account-section">
  <section class="login-card">
    <h3 class="login-heading">Login</h3>

    <div class="login-form">

          <!-- ERROR MESSAGE -->
          <div id="loginError" class="error-box" style="display:none;">
            <i class="fa-solid fa-circle-exclamation"></i>
            <span id="loginErrorText"></span>
          </div>


      <!-- <div id="loginError" style="display: none;"></div> -->

      <!-- Email -->
      <div class="form-group">
        <label for="email">Email <span>*</span></label>
        <input type="email" id="email" name="email" placeholder="Enter your email" />
      </div>

      <!-- Password -->
      <div class="form-group">
        <label for="password">Password<span>*</span></label>
        <input type="password" id="password" name="password" placeholder="Enter your password" />
      </div>

      <!-- Forgot Password -->
      <a href="/forgotpassword" class="forgot-link">Forgot password?</a>

      <!-- Login Button -->
      <!-- <button type="submit" class="login-btn" id="">Login</button> -->
      <button type="button" class="login-btn" onclick="loginUser()">Login</button>

      <!-- Divider -->
      <div class="divider">
        <span>Or continue with</span>
      </div>

      <!-- Social Buttons -->
      <div class="social-buttons">
        <button type="button" class="social google">
          <img src="https://cdn-icons-png.flaticon.com/512/2991/2991148.png" alt="Google" />
          <p>&nbsp;Sign in with Google</p>
        </button>
      </div>

      <!-- Register -->
      <p class="register-text">
        Don’t have an account?
        <a href="/signup">Register here</a>
      </p>
    </div>
  </section>
</main>