<main class="account-section">
  <section class="login-card">
    <h3 class="login-heading">
      <%= title %>
    </h3>
    <p class="otp-text">
      To reset your password, please verify your email address.
    </p>

    <!-- ERROR MESSAGE -->
    <div class="error-box" id="signUpError" style="display: none;">
      <i class="fa-solid fa-circle-exclamation"></i>
      <span id="signUpErrorText">
      </span>
    </div>

    <div class="login-form">


      <!-- Email -->
      <div class="form-group">
        <label for="email">Email <span>*</span></label>
        <input type="email" id="email" name="email" placeholder="Enter your email" />
      </div>

      <!-- Privacy -->
      <a href="">
        <p class="privacy">privacy policy</p>
      </a>

      <!-- Register Button -->
      <button type="button" id="confirmBtn" onclick="getMail()" class="login-btn">
        Send OTP
      </button>

      <!-- Already Have Account -->
      <p class="register-text">
        Remembered your password?
        <a href="/login"> Log in</a>
      </p>
    </div>
  </section>
</main>