<!-- Simple About Header -->
  <section class="top-header">
    <h1>About</h1>
  </section>

  <main class="main-body" aria-labelledby="about-heading">
    <!-- header / intro -->
    <header class="page-head">
      <div class="eyebrow">About JerseyGarage</div>
      <h2 id="about-heading" class="title">We design jerseys that fans love to wear.</h2>
      <p class="lede">At JerseyGarage we craft curated football jerseys and premium sportswear — focusing on authentic detail, sustainable materials, and the fan experience. We combine knowledge with passion to deliver pieces collectors and fans feel proud to wear.</p>
    </header>

    <!-- The Store -->
    <section class="the-store" aria-labelledby="store-heading">
      <div class="store-text">
        <h3 id="store-heading">The Store</h3>
        <p>Our flagship selection includes rare retro kits, current-season replica jerseys, and limited-run collaborations. Each product is photographed and inspected before shipping to ensure you receive premium quality.</p>
        <p style="margin-top:12px;color:var(--muted)">Open every day — shipments worldwide. Need help? Contact our support team for sizing and availability.</p>
        <div style="margin-top:18px">
          <button class="store-btn" onclick="window.location.href='#trending'">Shop Collection</button>
        </div>
      </div>

      <div class="store-image" role="img" aria-label="Store display placeholder">
        <div class="placeholder"><img src="/images/user/about/football_legends-hero-image.webp" alt="pele" style="width:100%; height:100%; object-fit:cover; border-radius:8px;"></div>
      </div>
    </section>

    <!-- Why -->
    <section class="why" aria-labelledby="why-heading">
      <div class="why-card">
        <h4 id="why-heading">Fueling your passion</h4>
        <p>We source quality fabrics and partner with manufacturers that respect craftsmanship. Our goal is to provide jerseys with accurate detailing — badges, piping, sponsor prints and true-to-shirt colours — so every fan gets the authentic look and feel.</p>
      </div>

      <div class="why-card">
        <h4>How we work</h4>
        <p>Every product passes through a multi-point check: design verification, fabric profiling, print fidelity and final QA. We also take pride in packaging that protects your item in transit and offers an unboxing experience fans love.</p>
      </div>
    </section>

    <!-- Quote block -->
    <section class="quote-block" aria-label="Inspirational quote">
      <div class="q-left">
        <blockquote>“Success is no accident. It is hard work, perseverance, learning, studying, sacrifice and most of all, love of what you are doing.”</blockquote>
        <div style="margin-top:12px;color:rgba(255,255,255,0.75);font-weight:600">— Pelé</div>
      </div>
      <div class="q-right"><img src="/images/user/about/pele-quote.webp" alt="pele" style="width:100%; height:100%; object-fit:cover; border-radius:8px;"></div>
    </section>
  </main>