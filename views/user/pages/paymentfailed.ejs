<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">

<div class="payment-failed-wrapper">
  <div class="payment-failed-card">

    <div class="fail-icon-wrap">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"
        stroke-linejoin="round">
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </div>

    <h2>Payment Failed</h2>
    <p>Your payment could not be processed. Please check your payment details and try again.</p>

    <div class="reasons-box">
      <p>Possible reasons:</p>
      <ul>
        <li>Insufficient funds</li>
        <li>Invalid card details</li>
        <li>Bank declined transaction</li>
        <li>Network connectivity issues</li>
      </ul>
    </div>

    <a href="/user/orders/<%= orderId %>#retryPayment" class="btn-try-again">Try Again</a>
    <a href="/support" class="contact-support">Contact Support</a>

  </div>
</div>