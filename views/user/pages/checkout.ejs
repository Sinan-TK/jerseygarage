<div class="checkout-container">

    <!-- LEFT SECTION -->
    <div class="checkout-left">

        <h1 class="page-title">Checkout</h1>

        <!-- SHIPPING -->
        <section class="card">
            <h2>Shipping Details</h2>
            <p class="muted">Select Shipping Address</p>

            <% addresses.forEach((address)=>{ %>
                <label class="radio-card <%= address.is_default ? 'active':'' %>">
                    <input type="radio" name="address" value="<%= address._id %>" <%=address.is_default ? 'checked' :''
                        %>/>
                    <div class="radio-content">

                        <div class="title">
                            <%= address.address_type %>
                                <% if(address.is_default){ %><span class="badge">Default</span>
                                    <% } %>
                        </div>

                        <p>
                            <%= address.full_name %>
                        </p>
                        <p>
                            <%= address.phone_no %>
                        </p>
                        <p>
                            <%= address.address_line %>
                        </p>
                        <p>
                            <%= address.city %>, <%= address.zip_code %>
                        </p>
                        <p>
                            <%= address.state %>, <%= address.country %>
                        </p>
                    </div>
                    <span class="edit" onclick="openEditAddressModal(this)"
                        data-address="<%- encodeURIComponent(JSON.stringify(address)) %>">Edit</span>
                </label>
                <% })%>

                    <label class="radio-card" onclick="openAddAddressModal()">
                        <input type="radio" name="address" />
                        <div class="radio-content">
                            <div class="title">
                                <%= addresses.length===0?"Add address": "Use a different address" %>
                            </div>
                        </div>
                    </label>
        </section>

        <!-- PAYMENT -->
        <section class="card">
            <h2>Payment Method</h2>

            <label class="radio-card">
                <input type="radio" name="payment" value="Razorpay" />
                <div class="radio-content">
                    <div class="title">Razorpay</div>
                    <p class="muted">Razorpay UPI</p>
                </div>
            </label>

            <label class="radio-card">
                <input type="radio" name="payment" value="Wallet" />
                <div class="radio-content">
                    <div class="title">Wallet</div>
                    <p class="muted">Wallet Balance : ₹<%= wallet.balance %></p>
                </div>
            </label>

            <label id="codLabel" class="radio-card <%= total > 500 ? 'disabled' : '' %>">
                <input type="radio" name="payment" value="COD" <%=total> 500 ? 'disabled' : '' %>
                />
                <div class="radio-content">
                    <div class="title">COD</div>
                    <p class="muted">Cash on Delivery</p>
                </div>
            </label>


            <p id="codText" class="muted <%= total > 500 ? 'small':'hidden' %> ">
                COD available only for orders above ₹500
            </p>
        </section>

        <button class="place-order">PLACE ORDER</button>
    </div>

    <!-- RIGHT SECTION -->
    <aside class="checkout-right">
        <div class="summary-card">
            <% if(warning.length !==0){ %>
                <div class="warning-message">
                    <h3><i class="fa-solid fa-triangle-exclamation"></i>warning</h3>
                    <ul>
                        <% warning.forEach((warn)=>{ %>
                            <li>
                                <%= warn %>
                            </li>
                            <% }) %>
                    </ul>
                </div>
                <% } %>

                    <h3>Product Details</h3>

                    <% items.forEach((item)=>{%>

                        <div class="product">
                            <div class="product-img">
                                <img src="<%= item.image %>" />
                            </div>
                            <div>
                                <p class="product-name">
                                    <%= item.name %>
                                </p>
                                <p class="muted">
                                    <%= item.size %>
                                </p>
                                <p class="muted">
                                    Quantity: <%= item.quantity %>
                                </p>
                                <strong>₹<%= item.unit_price %>.00</strong>
                            </div>
                        </div>

                        <% }) %>

                            <div class="divider"></div>

                            <p class="delivery">Estimated Delivery: <strong>Oct 15 - Oct 18</strong></p>

                            <div class="divider"></div>

                            <h3>Order Summary</h3>

                            <div class="row">
                                <span>Subtotal (<%= items.length %> items)</span>
                                <span>₹<%= (subtotal).toFixed(2) %></span>
                            </div>
                            <div class="row">
                                <span>Shipping</span>
                                <span>₹<%= (shippingCharge).toFixed(2) %></span>
                            </div>
                            <div class="row">
                                <span>GST</span>
                                <span>₹<%= (gstAmount).toFixed(2) %></span>
                            </div>

                            <div class="row total">
                                <span>Total</span>
                                <span id="totalAmount">₹<%= (total).toFixed(2) %></span>
                            </div>

                            <div class="couponText hidden" id="couponText">
                                Coupon applied successfully 🎉
                            </div>

                            <div class="promo-dropdown">
                                <select id="promoSelect">
                                    <option  value="">Select Coupon</option>
                                    <% coupons.forEach((coupon)=>{ %>
                                        <option value="<%= coupon.code %>">
                                            <%= coupon.code %>
                                        </option>
                                        <% }) %>
                                </select>

                                <button id="applyPromoBtn">APPLY</button>
                            </div>

        </div>
    </aside>

</div>


<!-- Add Address Modal -->
<div class="modal-overlay" id="addAddressModal">
    <div class="modal">
        <div class="modal-header">
            <h3>Add New Address</h3>
            <button class="close-btn" onclick="closeAddAddressModal()">×</button>
        </div>

        <form id="addAddressForm">
            <div class="form-grid">
                <div class="form-group">
                    <label>Full Name</label>
                    <input type="text" name="full_name">
                </div>

                <div class="form-group">
                    <label for="address_type">Address Type</label>
                    <select name="address_type" id="address_type">
                        <option value="Home">Home</option>
                        <option value="Work">Work</option>
                        <option value="Other">Other</option>
                    </select>
                </div>


                <div class="form-group full">
                    <label>Phone Number</label>
                    <input type="text" name="phone_no">
                </div>

                <div class="form-group full">
                    <label>Address Line</label>
                    <input type="text" name="address_line">
                </div>

                <div class="form-group">
                    <label>City</label>
                    <input type="text" name="city">
                </div>

                <div class="form-group">
                    <label>State</label>
                    <input type="text" name="state">
                </div>

                <div class="form-group">
                    <label>ZIP Code</label>
                    <input type="text" name="zip_code">
                </div>

                <div class="form-group">
                    <label>Country</label>
                    <input type="text" name="country" value="India">
                </div>
            </div>

            <div class="modal-actions">
                <button type="button" class="btn-outline" onclick="closeAddAddressModal()">
                    Cancel
                </button>
                <button type="submit" class="btn-primary" id="submitBtn">
                    Save Address
                </button>
            </div>
        </form>
    </div>
</div>


<!-- ===============================
     EDIT ADDRESS MODAL
================================ -->
<div class="modal-overlay" id="editAddressModal">
    <div class="modal">
        <div class="modal-header">
            <h3>Edit Address</h3>
            <button class="close-btn" onclick="closeEditAddressModal()">×</button>
        </div>

        <form id="editAddressForm">
            <input type="hidden" name="address_id" id="edit_address_id" />

            <div class="form-grid">
                <div class="form-group">
                    <label>Full Name</label>
                    <input type="text" name="full_name" id="edit_full_name" />
                </div>

                <div class="form-group">
                    <label>Address Type</label>
                    <select name="address_type" id="edit_address_type">
                        <option value="Home">Home</option>
                        <option value="Work">Work</option>
                        <option value="Other">Other</option>
                    </select>
                </div>

                <div class="form-group full">
                    <label>Phone Number</label>
                    <input type="text" name="phone_no" id="edit_phone_no" />
                </div>

                <div class="form-group full">
                    <label>Address Line</label>
                    <input type="text" name="address_line" id="edit_address_line" />
                </div>

                <div class="form-group">
                    <label>City</label>
                    <input type="text" name="city" id="edit_city" />
                </div>

                <div class="form-group">
                    <label>State</label>
                    <input type="text" name="state" id="edit_state" />
                </div>

                <div class="form-group">
                    <label>ZIP Code</label>
                    <input type="text" name="zip_code" id="edit_zip_code" />
                </div>

                <div class="form-group">
                    <label>Country</label>
                    <input type="text" name="country" id="edit_country" />
                </div>

                <div class="form-group checkbox full">
                    <input type="checkbox" id="edit_is_default" name="is_default" />
                    <label for="edit_is_default">Set as default address</label>
                </div>
            </div>

            <div class="modal-actions">
                <button type="button" class="btn-outline" onclick="closeEditAddressModal()">
                    Cancel
                </button>
                <button type="submit" class="btn-primary" id="edit-submit">
                    Update Address
                </button>
            </div>
        </form>
    </div>
</div>