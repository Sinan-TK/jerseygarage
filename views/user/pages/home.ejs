<main class="main-body">
  <!-- HERO -->
  <section class="hero-banner">
    <div class="hero-content">
      <!-- <h1>Now Available</h1> -->
      <a href="/shop" class="shop-btn">Shop Now</a>
    </div>
  </section>

  <!-- PRODUCTS -->
  <section class="trending-products">
    <h2>Trending Products</h2>
    <div class="product-grid">
      <% products.forEach((product)=> {%>
        <a href="/product/<%= product._id %>">
          <div class="product-item">

            <% let selectedVariant=null; for (let size of ["S", "M" , "L" , "XL" , "XXL" ]) { const
              match=product.variants.find( (v)=> v.size === size && v.is_available === true && v.stock > 0
              );

              if (match) {
              selectedVariant = match;
              break;
              }
              }
              %>

              <% 
                const applicableOffers = [];

                for (let i = 0; i < offers.length; i++) {
                  const offer = offers[i];
                  if (
                    offer.offerApplyType === "product" &&
                    offer.productIds &&
                    offer.productIds.find(function (id) {
                      return id.toString() === product._id.toString();
                    })
                  ) {
                    applicableOffers.push(offer);
                    continue;
                  }
                  if (
                    offer.offerApplyType === "category" &&
                    offer.categoryIds &&
                    offer.categoryIds.find(function (id) {
                      return id.toString() === product.category.toString();
                    })
                  ) {
                    applicableOffers.push(offer);
                  }
                }%>

                  <% if (applicableOffers.length !== 0) { %>
                    <div class="offer-div">
                      <span>Offer</span>
                    </div>
                    <% } %>

                      <!-- WISHLIST ICON -->
                      <% if(user){ %>
                        <div class="product-actions">
                          <% let isWishlisted=false; if (wishlist && wishlist.items && selectedVariant) { for (let item
                            of wishlist.items) { if ( item.variant_id.toString()===selectedVariant._id.toString() ) {
                            isWishlisted=true; break; } } } %>
                            <button data-variant="<%= selectedVariant._id %>"
                              class="wishlist-btn <%= isWishlisted ? `isWishlistedTrue` : `isWishlistedFalse` %>"
                              title="Add to Wishlist">
                              <i class="fa-regular fa-heart"></i>
                            </button>
                        </div>
                        <% } %>

                          <img src="<%=product.images[0]%>" alt="<%=product.name%>">

                          <div class="product-details">
                            <p class="product-name">
                              <%= product.name %>
                            </p>

                            <div class="price-section">
                              <p class="product-price-normal">
                                <%
                                  let displayPrice = selectedVariant.base_price;
                                  let bestPrice = displayPrice;
                                  let appliedOffer = null;
                                %>
  
  
  
  
  
                                <%
                                  for (let i = 0; i < applicableOffers.length; i++) {
                                    const offer = applicableOffers[i];
                                    let priceAfterOffer = displayPrice;
  
                                    if (offer.discountType === "percentage") {
                                      priceAfterOffer -= (priceAfterOffer * offer.discountValue) / 100;
                                    } else {
                                      priceAfterOffer -= offer.discountValue;
                                    }
  
                                    if (priceAfterOffer < bestPrice) {
                                      bestPrice = priceAfterOffer;
                                      appliedOffer = offer;
                                    }
                                  }
  
                                  displayPrice = bestPrice;
                                %>

                                <% if (selectedVariant) { %>
                                  ₹<%= displayPrice < selectedVariant.base_price? selectedVariant.base_price : selectedVariant.normal_price  %>
                                    <% } else { %>
                                      <span>Out of Stock</span>
                                      <% } %>
                              </p>

                              <p class="product-price-base">

                                  ₹<%= displayPrice.toFixed(0) %>
                              </p>
                            </div>

                            <!-- ADD TO CART BUTTON -->
                            <button data-variant="<%= selectedVariant._id %>" data-product="<%= product._id %>"
                              class="add-to-cart-btn">
                              <i class="fa-solid fa-cart-shopping"></i>
                              Add to Cart
                            </button>
                          </div>
          </div>

        </a>

        <% }) %>
    </div>
  </section>

  <!-- REVIEWS -->
  <section class="customer-reviews">
    <h2>Customer Reviews</h2>
    <div class="review-container">
      <div class="review-card">
        <div class="quote-icon">❝</div>
        <p class="review-text">Good quality and received in 3 days. Comfortable jersey, logo quality is great. Loved it!
        </p>
        <div class="review-author"><i class="fas fa-user-circle"></i><span>Nihin E</span></div>
        <div class="review-stars">★★★★★</div>
      </div>
      <div class="review-card">
        <div class="quote-icon">❝</div>
        <p class="review-text">Best jersey I’ve ever purchased. Quality is superb, really loved it. Must buy for fans!
        </p>
        <div class="review-author"><i class="fas fa-user-circle"></i><span>Nabeela C</span></div>
        <div class="review-stars">★★★★★</div>
      </div>
      <div class="review-card">
        <div class="quote-icon">❝</div>
        <p class="review-text">Amazing products! Ordered multiple jerseys, never disappointed. Great customer service!
        </p>
        <div class="review-author"><i class="fas fa-user-circle"></i><span>Hindustani Bhai</span></div>
        <div class="review-stars">★★★★★</div>
      </div>
      <div class="review-card">
        <div class="quote-icon">❝</div>
        <p class="review-text">Good quality and received in 3 days. Comfortable jersey, logo quality is great. Loved it!
        </p>
        <div class="review-author"><i class="fas fa-user-circle"></i><span>Nihin E</span></div>
        <div class="review-stars">★★★★★</div>
      </div>
    </div>
  </section>

  <!-- PROMO -->
  <section class="welcome-promo">
    <div class="promo-text-area">
      <p class="follow-us">Follow us</p>
      <h2>Welcome to JerseyGarage</h2>
      <p class="tagline">— where your game shines. Discover our premium jerseys and wear your passion!</p>
      <div class="promo-logo">
        <p class="jersey-brand">JerseyGarage</p>
      </div>
    </div>
    <div class="promo-image-area">
      <img src="https://cdn.cosmos.so/c3d08d8b-eadf-42a0-bbb0-1f85d21f2194?format=jpeg" alt="Couple in jerseys">
    </div>
  </section>
