<section class="address-container">

    <div class="address-header">
        <h2>Saved Addresses</h2>
        <button class="btn-primary" onclick="openAddAddressModal()">Add New Address</button>
    </div>

    <% if(addresses.length===0){%>
        <div class="address-card">
            <div class="address-info">
                <h4>No address added yet</h4>
            </div>
        </div>
        <%} else{%>
            <% addresses.forEach((address)=>{ %>
                <div class="address-card">
                    <div class="address-info">
                        <h4>
                            <%= address.address_line1%>
                        </h4>
                        <p>
                            <%= address.full_name %>
                        </p>
                        <p>
                            <%= address.address_line1 %>, <%= address.address_line2 %>
                        </p>
                        <p>
                            <%= address.city %>, <%= address.zip_code %>
                        </p>
                        <p>
                            <%= address.phone_no %>
                        </p>
                        <p>
                            <%= address.country %>
                        </p>
                    </div>
                    <div class="edit-delete">
                        <button class="edit-link"><i class="fa-solid fa-pen-to-square"></i></button>
                        <% if(!address.is_default){ %>
                            <button class="delete-link" data-id="<%= address._id %>"><i class="fa-solid fa-trash"></i></button>
                            <% }else{ %>
                                <p class="default-txt">default</p>
                                <%}%>
                    </div>
                </div>
                <%})}%>
</section>

<!-- Add Address Modal -->
<div class="modal-overlay" id="addAddressModal">
    <div class="modal">
        <div class="modal-header">
            <h3>Add New Address</h3>
            <button class="close-btn" onclick="closeAddAddressModal()">×</button>
        </div>

        <form id="addAddressForm">
            <div class="form-grid">
                <div class="form-group">
                    <label>Full Name</label>
                    <input type="text" name="full_name">
                </div>

                <div class="form-group">
                    <label>Phone Number</label>
                    <input type="text" name="phone_no">
                </div>

                <div class="form-group full">
                    <label>Address Line 1</label>
                    <input type="text" name="address_line1">
                </div>

                <div class="form-group full">
                    <label>Address Line 2</label>
                    <input type="text" name="address_line2">
                </div>

                <div class="form-group">
                    <label>City</label>
                    <input type="text" name="city">
                </div>

                <div class="form-group">
                    <label>State</label>
                    <input type="text" name="state">
                </div>

                <div class="form-group">
                    <label>ZIP Code</label>
                    <input type="text" name="zip_code">
                </div>

                <div class="form-group">
                    <label>Country</label>
                    <input type="text" name="country" value="India">
                </div>

                <div class="form-group checkbox full">
                    <input type="checkbox" id="is_default" name="is_default">
                    <label for="is_default">Set as default address</label>
                </div>
            </div>

            <div class="modal-actions">
                <button type="button" class="btn-outline" onclick="closeAddAddressModal()">
                    Cancel
                </button>
                <button type="submit" class="btn-primary" id="submitBtn">
                    Save Address
                </button>
            </div>
        </form>
    </div>
</div>