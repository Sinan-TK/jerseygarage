<main class="account-main">

  <!-- PERSONAL INFORMATION -->
  <section class="card personal-card">
    <div class="card-header">
      <h3>Personal Information</h3>
      <div class="edit-btns">
        <button class="edit-btn"><i class="fa-regular fa-pen-to-square"></i> Edit</button>
        <button onclick="editSubmit()" class="edit-btn edit-submit">Submit</button>
        <a href="/user/profile" class="edit-btn edit-cancel">Cancel</a>
      </div>
    </div>

    <div class="info-grid">
      <div class="info-item">
        <span>Full Name</span>
        <p id="full_name">
          <%= userDetails.full_name %>
        </p>
      </div>

      <div class="info-item">
        <span>Email Address</span>
        <p id="email">
          <%= userDetails.email %>
        </p>
      </div>

      <div class="info-item">
        <span>Phone Number</span>
        <p id="phone_no">
          <%= userDetails.phone_no !=null ? userDetails.phone_no : " N/A" %>
        </p>
      </div>

      <div class="info-item">
        <span>Member Since</span>
        <p id="date">
          <%= new Date(userDetails.createdAt).toLocaleDateString("en-US") %>
        </p>
      </div>

      <div class="info-item" onclick="openPasswordModal()">
        <span>Password</span>
        <p>******** <a href="#" class="link"><i class="fa-regular fa-pen-to-square"></i> New Password</a>
        </p>
      </div>
    </div>
  </section>

  <!-- STATS -->
  <section class="stats-row">

    <div class="card stat-card">
      <div class="stat-top">
        <span>Wallet Balance</span>
        <a href="/user/wallet" class="link">See details →</a>
      </div>
      <h2>₹<%= (userDetails.wallet.balance).toFixed(2) %>
      </h2>
    </div>

    <div class="card stat-card">
      <div class="stat-top">
        <span>Total Referrals</span>
        <a href="/user/referral" class="link">See details →</a>
      </div>
      <h2>
        <%= userDetails.referral_count %>
      </h2>
    </div>

  </section>

</main>

<!-- Change Password Modal -->
<div class="modal-overlay" id="passwordModal">

  <div class="modal-box">

    <h3>Change Password</h3>
    <div class="error-box">
      <p class="error-text-password">error</p>
    </div>


    <form id="passwordForm">

      <!-- Current Password -->
      <div class="form-group">
        <label>Current Password</label>

        <div class="password-wrapper">
          <input type="password" id="currentPassword" placeholder="Enter current password" />
          <i class="fa-solid fa-eye toggle-password" data-target="currentPassword"></i>
        </div>
      </div>

      <div class="form-group">
        <label>New Password</label>

        <div class="password-wrapper">
          <input type="password" id="newPassword" placeholder="Enter new password" />
          <i class="fa-solid fa-eye toggle-password" data-target="newPassword"></i>
        </div>
      </div>

      <div class="form-group">
        <label>Confirm Password</label>

        <div class="password-wrapper">
          <input type="password" id="confirmPassword" placeholder="Re-enter new password" />
          <i class="fa-solid fa-eye toggle-password" data-target="confirmPassword"></i>
        </div>
      </div>


      <!-- Buttons -->
      <div class="modal-actions">

        <button type="button" class="btn-cancel" onclick="closePasswordModal()">
          Cancel
        </button>

        <button type="submit" class="btn-save">
          Update Password
        </button>

      </div>

    </form>

  </div>

</div>


<div id="avatarModal" class="avatar-modal-overlay">
  <div class="avatar-modal-box">

    <button id="avatarModalClose" class="avatar-modal-close">
      <i class="fa-solid fa-xmark"></i>
    </button>

    <h3 class="avatar-modal-title">Profile Picture</h3>

    <img id="avatarPreview" src="<%= user.avatar %>" class="avatar-modal-preview">

    <button id="changeAvatarBtn" class="avatar-change-btn">
      <i class="fa-solid fa-camera"></i> Change Photo
    </button>

    <button id="removeAvatarBtn" class="avatar-remove-btn">
      <i class="fa-solid fa-trash"></i> Remove Photo
    </button>

  </div>
</div>


<div id="cropModal" class="avatar-modal-overlay">
  <div class="avatar-modal-box crop-modal-wrap">

    <button id="cropModalClose" class="avatar-modal-close">
      <i class="fa-solid fa-xmark"></i>
    </button>

    <h3 class="avatar-modal-title">Crop Photo</h3>

    <div class="crop-image-container">
      <img id="cropImage">
    </div>

    <button id="cropSaveBtn" class="crop-save-btn">
      <i class="fa-solid fa-check"></i> Save Photo
    </button>

  </div>
</div>