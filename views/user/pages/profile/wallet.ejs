<section class="wallet-section">

    <div class="wallet-container">

        <!-- Wallet Balance -->
        <div class="wallet-card">

            <div class="wallet-info">
                <h3>Current Wallet Balance</h3>
                <h1>₹ <span id="balance">0</span></h1>
            </div>

            <button class="add-btn" id="addMoneyBtn">
                <i class="fa-solid fa-plus"></i> Add Money
            </button>

        </div>

        <!-- Transactions -->
        <div class="transactions">

            <h2>Transaction History</h2>

            <div id="transactionList">

            </div>
            <div class="pagination-bar">
                <span id="paginationInfo"></span>
                <div class="pagination-btns" id="pagination"></div>
            </div>

        </div>

    </div>

</section>

<!-- Add Money Modal -->
<div class="modal-overlay" id="addMoneyModal">

    <div class="modal-box">

        <!-- Header -->
        <div class="modal-header">
            <h3>Add Money to Wallet</h3>
            <button id="closeModal">&times;</button>
        </div>

        <!-- Body -->
        <div class="modal-body">

            <!-- Amount -->
            <label>Enter Amount (₹)</label>

            <input type="number" id="walletAmount" placeholder="Minimum ₹100" min="100" />

            <!-- Quick Buttons -->
            <div class="quick-amounts">
                <button data-amt="100">₹100</button>
                <button data-amt="200">₹200</button>
                <button data-amt="500">₹500</button>
                <button data-amt="1000">₹1000</button>
            </div>

            <!-- Payment Method -->
            <label>Payment Method</label>

            <div class="payment-method active">

                <img src="https://razorpay.com/favicon.png" alt="Razorpay" />

                <div>
                    <strong>Razorpay</strong>
                    <p>Pay securely via Razorpay</p>
                </div>

            </div>

            <!-- Proceed -->
            <button class="proceed-btn" id="proceedBtn" disabled>
                Proceed
            </button>

        </div>

    </div>

</div>